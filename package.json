{
  "name": "figma-library-maintenance-tools",
  "version": "1.0.0",
  "description": "A collection of CLI tools for auditing and maintaining Figma design libraries via the REST API",
  "type": "module",
  "bin": {
    "figma-lint-names": "./src/tools/lint-layer-names/cli.js",
    "figma-lint-duplicates": "./src/tools/lint-duplicate-siblings/cli.js",
    "figma-lint-autolayout": "./src/tools/lint-autolayout-values/cli.js",
    "figma-lint-radius": "./src/tools/lint-radius-values/cli.js",
    "figma-lint-text-styles": "./src/tools/lint-text-styles/cli.js",
    "figma-check-descriptions": "./src/tools/check-descriptions/cli.js",
    "figma-audit-properties": "./src/tools/audit-property-names/cli.js",
    "figma-scan-pages": "./src/tools/scan-page-hygiene/cli.js",
    "figma-lint-variants": "./src/tools/lint-variants/cli.js",
    "figma-lint-casing": "./src/tools/lint-casing/cli.js",
    "figma-lint-canvas": "./src/tools/lint-canvas/cli.js",
    "figma-run-script": "./src/tools/run-script/cli.js",
    "figma-audit-a11y-target-sizes": "./src/tools/audit-a11y-target-sizes/cli.js",
    "figma-audit-a11y-states": "./src/tools/audit-a11y-missing-states/cli.js",
    "figma-audit-a11y-descriptions": "./src/tools/audit-a11y-descriptions/cli.js",
    "figma-lint-layer-order": "./src/tools/lint-layer-order/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "figma",
    "design-system",
    "lint",
    "automation",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "vitest": "^3.2.1"
  }
}
