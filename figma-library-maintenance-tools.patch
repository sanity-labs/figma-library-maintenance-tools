+      ],
+    };
+    const issues = detectHardcodedText(component, "Card", null, new Map());
+    expect(issues[0].fontSize).toBe(16);
+    expect(issues[0].fontFamily).toBe("Inter");
+    expect(issues[0].fontStyle).toBe("Semi Bold");
